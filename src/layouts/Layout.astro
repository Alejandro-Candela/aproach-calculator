---
import '../styles/global.css';
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="AI Architecture Assessment" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#FAF9F6] text-[#33312E] min-h-screen font-sans selection:bg-[#E8E2D9]">
        <nav class="w-full border-b border-[#E5E2DC] bg-[#FAF9F6]/80 backdrop-blur-md sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 rounded bg-[#E8E2D9] border border-[#D5CFCD] flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#5C5855" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                    </div>
                    <span class="font-serif italic text-xl tracking-tight text-[#33312E]">Architect.ai</span>
                </div>
                <div class="text-sm font-medium text-[#8A8580] font-sans">Enterprise Standards</div>
            </div>
        </nav>

		<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
			<slot />
		</main>
	</body>
</html>
<style is:global>
    :root {
        font-family: 'Inter', system-ui, sans-serif;
    }
    
    h1, h2, h3, h4, h5, h6, .font-serif {
        font-family: 'Newsreader', Georgia, serif;
    }
</style>
