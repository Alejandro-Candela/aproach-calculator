---
import Layout from '../layouts/Layout.astro';
import AssessmentForm from '../components/AssessmentForm';
import ResultsDashboard from '../components/ResultsDashboard';
---

<Layout title="Architect.ai | Enterprise Approach Calculator">
    <!-- Decorative Botanical SVGs (Hand-drawn organic minimalist style) -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
        <!-- Botanical Mustard Star/Flower -->
        <svg class="absolute top-12 left-[15%] w-24 h-24 text-botanical-mustard opacity-90" viewBox="0 0 100 100" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M50.5 4.5C53.2 25.1 63.8 34.7 82.2 39.5C92 42.1 96 46.5 94.5 53.5C92 64.9 76.5 67.5 61 73C53 75.9 52 83.5 54.5 95C55.5 99.5 47 101.5 44 95.5C38.6 84.4 31.5 76.5 17 74C6.5 72.2 1.5 66 3 55.5C4 48 11.5 44 26 40C39.5 36.3 45.5 28.5 43.5 10C42.5 1.5 49 -1 50.5 4.5Z" />
        </svg>

        <!-- Hand-drawn dots cluster -->
        <svg class="absolute top-[25%] left-[8%] w-16 h-16 text-botanical-navy opacity-80" viewBox="0 0 50 50" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <circle cx="10" cy="15" r="2.5" />
            <circle cx="22" cy="10" r="2" />
            <circle cx="35" cy="18" r="3" />
            <circle cx="15" cy="28" r="1.5" />
            <circle cx="28" cy="25" r="2.5" />
            <circle cx="42" cy="30" r="2" />
            <circle cx="20" cy="40" r="3" />
            <circle cx="32" cy="38" r="2" />
        </svg>

        <!-- Deep Green Cactus/Leaf shape -->
        <svg class="absolute bottom-10 left-[-2%] w-64 h-64 text-botanical-green-dark opacity-95" viewBox="0 0 200 200" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 180 C15 130, 25 80, 50 60 C80 35, 100 60, 95 90 C90 120, 80 150, 75 180 Z" />
            <path d="M50 120 C40 90, 10 70, 5 90 C0 110, 20 130, 30 150 Z" />
            <path d="M90 130 C110 100, 140 80, 145 100 C150 120, 120 140, 100 160 Z" />
        </svg>

        <!-- Coral hand-drawn flower on top of the green -->
        <svg class="absolute bottom-24 left-[10%] w-16 h-16 text-botanical-coral opacity-100" viewBox="0 0 100 100" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M48 10C55 12 58 22 55 32C65 25 75 22 80 30C85 38 75 48 65 52C75 56 86 62 82 72C78 82 65 78 55 70C58 80 55 92 48 90C41 88 38 78 41 68C31 75 21 78 16 70C11 62 21 52 31 48C21 44 10 38 14 28C18 18 31 22 41 30C38 20 41 8 48 10Z" />
        </svg>

        <!-- Light Green blob with drawn lines pattern -->
        <svg class="absolute top-[35%] right-[-5%] w-72 h-72 text-botanical-green-light opacity-90" viewBox="0 0 200 200" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M120 20 C160 30, 190 70, 180 110 C170 150, 120 180, 80 170 C40 160, 10 120, 20 80 C30 40, 80 10, 120 20 Z" />
        </svg>
        
        <!-- Abstract squiggly line -->
        <svg class="absolute top-[20%] right-[15%] w-48 h-48 text-botanical-green-dark opacity-60 fill-none stroke-current stroke-[1.5]" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 100 Q 50 20, 100 100 T 180 100" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </div>

	<div class="relative z-10 flex flex-col items-center text-center max-w-4xl mx-auto mb-20 px-4 pt-12 md:pt-16">
        <div class="inline-flex items-center px-4 py-2 rounded-full border-2 border-botanical-navy bg-transparent text-xs font-bold text-botanical-navy uppercase tracking-widest mb-10">
            <span class="w-2 h-2 rounded-full bg-botanical-mustard mr-2"></span>
            Enterprise Grade
        </div>
		<h1 class="text-6xl md:text-7xl lg:text-[6rem] font-serif font-normal tracking-tight text-botanical-navy mb-8 leading-[1.05]">
			Design your <br/>
			<span class="text-botanical-coral italic">AI Architecture</span>
		</h1>
		<p class="text-lg md:text-xl text-botanical-navy/80 leading-relaxed font-sans max-w-2xl mx-auto">
			Evaluate your enterprise requirements against 2026 standards. We analyze data volumetry, complexity, and privacy needs to calculate the exact technical stack for your project.
		</p>
	</div>

	<div class="relative z-10">
		<AssessmentForm client:load />
		<ResultsDashboard client:load />
	</div>
</Layout>
