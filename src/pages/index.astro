---
import Layout from '../layouts/Layout.astro';
import AssessmentForm from '../components/AssessmentForm';
import ResultsDashboard from '../components/ResultsDashboard';
---

<Layout title="Architect.ai | Enterprise Approach Calculator">
	<div className="relative z-10 text-center max-w-3xl mx-auto mb-16">
		<h1 className="text-5xl md:text-6xl font-extrabold tracking-tight text-white mb-6">
			Discover your optimal <br/>
			<span className="bg-clip-text text-transparent bg-gradient-to-r from-emerald-400 to-cyan-400">AI Architecture</span>
		</h1>
		<p className="text-xl text-slate-400 leading-relaxed font-light">
			Evaluate your enterprise requirements against 2026 standards limits. We analyze token volumetry, ENS compliance, and workflow complexity to calculate the exact tech stack you need.
		</p>
	</div>

	<div className="relative">
		{/* Client-side hydrated components */}
		<AssessmentForm client:load />
		<ResultsDashboard client:load />
	</div>
</Layout>
