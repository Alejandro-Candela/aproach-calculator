---
import Layout from '../layouts/Layout.astro';
import AssessmentForm from '../components/AssessmentForm';
import ResultsDashboard from '../components/ResultsDashboard';
---

<Layout title="Architect.ai | Enterprise Approach Calculator">
	<div class="relative z-10 flex flex-col items-center text-center max-w-4xl mx-auto mb-20 px-4 pt-12 md:pt-16">
        <div class="inline-flex items-center px-3 py-1.5 rounded-full border border-[#D5CFCD] bg-white text-xs font-semibold text-[#5C5855] uppercase tracking-widest mb-8 shadow-sm">
            <span class="w-2 h-2 rounded-full bg-[#D97757] mr-2"></span>
            Enterprise Grade Assessment
        </div>
		<h1 class="text-5xl md:text-7xl lg:text-[5rem] font-serif font-normal tracking-tight text-[#1A1918] mb-8 leading-[1.05]">
			Design your optimal <br/>
			<span class="italic text-[#D97757] font-medium">AI Architecture.</span>
		</h1>
		<p class="text-lg md:text-xl text-[#5C5855] leading-relaxed font-light font-sans max-w-2xl mx-auto">
			Evaluate your enterprise requirements against 2026 standards. We analyze data volumetry, complexity, and privacy needs to calculate the exact technical stack you require.
		</p>
	</div>

	<div className="relative">
		{/* Client-side hydrated components */}
		<AssessmentForm client:load />
		<ResultsDashboard client:load />
	</div>
</Layout>
